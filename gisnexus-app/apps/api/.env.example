# Postgres connection string (must point at a database with PostGIS available)
# Local docker-compose: postgres://gisnexus:gisnexus@localhost:5432/gisnexus
# Supabase: get this from Project Settings -> Database -> Connection string (URI, "Session" mode)
DATABASE_URL=postgres://gisnexus:gisnexus@localhost:5432/gisnexus

# Long random string used to sign auth JWTs. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# Port the API listens on
PORT=4000

# Comma-separated list of origins allowed to call the API (your web app's URL)
CORS_ORIGIN=http://localhost:5173

# Max upload size in MB for layer file uploads
MAX_UPLOAD_MB=25
